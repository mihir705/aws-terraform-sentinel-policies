# SNS topics must use KMS encryption.
#
# Module : terraform-aws-modules/sns/aws
# Resource: aws_sns_topic

import "tfplan/v2" as tfplan
import "tfplan-functions" as plan

const = {
	"policy_name": "sns-encryption-required",
	"message":     "SNS topics must specify kms_master_key_id for encryption.",
}

topics = plan.find_resources("aws_sns_topic")

violations = plan.filter_attribute_does_not_exist(
	topics,
	"kms_master_key_id",
	true,
)

main = rule {
	length(violations["messages"]) is 0
}
